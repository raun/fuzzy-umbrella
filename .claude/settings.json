{
  "permissions": {
    "allow": [],
    "deny": []
  },
  "env": {
    "BUDGET_MAX_AGENT_CALLS": "20",
    "BUDGET_MAX_TOKENS": "200000",
    "BUDGET_TOKENS_PER_CALL": "8000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/budget_guard.py pre"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/container_guard.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT\" | python3 -c \"import sys, json; d=json.load(sys.stdin); path=d.get('file_path',''); blocked=['.env','.env.local','.env.production','credentials.json','secrets.yaml','secrets.json']; sys.exit(1) if any(path.endswith(b) for b in blocked) else sys.exit(0)\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/budget_guard.py post"
          }
        ]
      }
    ]
  }
}
